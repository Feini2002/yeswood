# Local server
PORT=4173

# mock = use built-in sample DingTalk AI Table records
# dingtalk = call DingTalk accessToken and records/list from backend only
DINGTALK_MODE=mock

# Required for POST /api/sync. Keep this backend/admin only.
SYNC_API_KEY=change-this-sync-key
SYNC_MIN_INTERVAL_MS=60000

# Allows the browser UI to trigger backend sync through a same-origin guarded endpoint.
# Keep false unless this dashboard is protected by your network/auth boundary.
DASHBOARD_SYNC_ENABLED=false

# Local data files. SQLite is the local master-data base; JSON remains a short-term compatibility snapshot.
LOCAL_DATABASE_FILE=
LOCAL_CACHE_FILE=

# Real DingTalk settings. Do not put these in frontend code.
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_TOKEN_URL=
DINGTALK_TOKEN_METHOD=POST
DINGTALK_TOKEN_AUTH_MODE=appSecret
DINGTALK_RECORDS_LIST_URL=
DINGTALK_RECORDS_METHOD=POST
DINGTALK_ACCESS_TOKEN_HEADER=authorization
DINGTALK_PAGE_SIZE=100
DINGTALK_MAX_PAGES=200

# Put app/table/view/body parameters required by your records/list endpoint here.
DINGTALK_RECORDS_LIST_BODY_JSON={}

# Optional mapping from dashboard fields to DingTalk AI Table field names.
# Leave empty to rely on automatic field resolution (recommended).
# Use only when you need to force a specific DingTalk column for a standard field.
# Example:
# DINGTALK_FIELD_MAP_JSON={"name":"项目名称","province":"省份","businessType":"业态","storeStatus":"店态","status":"项目状态","owner":"负责人","progress":"硬装项目进度","startDate":"启动时间","dueDate":"计划开业时间"}
DINGTALK_FIELD_MAP_JSON={}
